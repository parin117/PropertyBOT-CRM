{
  "name": "property-crm-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint . --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@bull-board/api": "^8.0.0",
    "@bull-board/express": "^8.0.0",
    "@bull-board/ui": "^8.0.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.0",
    "express-basic-auth": "^1.2.1",
    "helmet": "^7.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autocannon": "^8.0.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0"
  }
}
