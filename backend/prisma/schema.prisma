generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  role         String        @default("agent")
  refreshToken String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  agentProfile Agent?
  appointments Appointment[]
  leads        Lead[]        @relation("AgentLeads")
  properties   Property[]

  @@index([email])
}

model Agent {
  id               String   @id @default(uuid())
  userId           String   @unique
  experience       Int      @default(0)
  specialization   String?
  performanceScore Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id           String        @id @default(uuid())
  title        String
  description  String
  price        Float
  city         String
  state        String
  address      String
  propertyType String
  bhk          Int
  bathrooms    Int
  area         String
  amenities    String
  images       String
  status       String
  featured     Boolean       @default(false)
  listedById   String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  availability String        @default("Available")
  locationId   String?
  appointments Appointment[]
  leads        Lead[]
  listedBy     User          @relation(fields: [listedById], references: [id])
  location     Area?         @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([city, state])
  @@index([propertyType, status])
  @@index([price])
  @@index([locationId])
}

model Customer {
  id                String         @id @default(uuid())
  name              String
  phone             String         @unique
  email             String         @unique
  budget            Float?
  preferredLocation String?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  appointments      Appointment[]
  conversations     Conversation[]
  leads             Lead[]
  reviews           Review[]

  @@index([email])
  @@index([phone])
}

model Lead {
  id              String   @id @default(uuid())
  customerId      String
  propertyId      String
  status          String   @default("NEW")
  source          String
  notes           String?
  assignedAgentId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  assignedAgent   User?    @relation("AgentLeads", fields: [assignedAgentId], references: [id])
  customer        Customer @relation(fields: [customerId], references: [id])
  property        Property @relation(fields: [propertyId], references: [id])

  @@index([customerId])
  @@index([propertyId])
  @@index([assignedAgentId])
}

model Conversation {
  id               String            @id @default(uuid())
  customerId       String
  messages         String
  aiSummary        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messagesList     Message[]
  outboundMessages OutboundMessage[]

  @@index([customerId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  from           String
  text           String
  timestamp      DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model AISession {
  id           String   @id @default(uuid())
  phone        String   @unique
  collected    String
  pendingField String?
  active       Boolean  @default(true)
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([phone])
  @@index([active])
  @@index([lastActivity])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model Review {
  id           String   @id @default(uuid())
  customerId   String
  reviewerName String
  rating       Int
  comment      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Appointment {
  id              String    @id @default(uuid())
  customerId      String
  propertyId      String?
  assignedAgentId String?
  scheduledAt     DateTime
  status          String    @default("SCHEDULED")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  assignedAgent   User?     @relation(fields: [assignedAgentId], references: [id])
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  property        Property? @relation(fields: [propertyId], references: [id])

  @@index([customerId])
  @@index([assignedAgentId])
  @@index([propertyId])
  @@index([scheduledAt])
}

model Analytics {
  id         String   @id @default(uuid())
  metric     String
  value      Float
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([metric])
}

model WebhookEvent {
  id            String             @id @default(uuid())
  messageId     String             @unique
  sender        String
  status        WebhookEventStatus @default(RECEIVED)
  processedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  failureCount  Int                @default(0)
  lastError     String?
  payload       Json
  queuedAt      DateTime?
  fallbackSent  Boolean            @default(false)
  metaTimestamp Int?
  sequenceId    BigInt             @default(autoincrement())

  @@index([status])
  @@index([sender, status, metaTimestamp, sequenceId])
}

model OutboundMessage {
  id             String                @id @default(uuid())
  conversationId String?
  webhookEventId String?
  metaMessageId  String?               @unique
  recipient      String
  content        String
  status         OutboundMessageStatus @default(PENDING)
  errorMessage   String?
  retryCount     Int                   @default(0)
  lastRetryAt    DateTime?
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  conversation   Conversation?         @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([metaMessageId])
  @@index([recipient])
  @@index([status])
  @@index([conversationId])
  @@index([webhookEventId])
}

model MetaWebhookEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  payload     Json
  processedAt DateTime @default(now())

  @@index([eventId])
}

model State {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cities    City[]

  @@index([name])
}

model City {
  id        String   @id @default(uuid())
  name      String
  stateId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  areas     Area[]
  state     State    @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@unique([name, stateId])
  @@index([stateId])
  @@index([name])
}

model Area {
  id         String     @id @default(uuid())
  name       String
  cityId     String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  city       City       @relation(fields: [cityId], references: [id], onDelete: Cascade)
  properties Property[]

  @@unique([name, cityId])
  @@index([cityId])
  @@index([name])
}

enum WebhookEventStatus {
  RECEIVED
  QUEUED
  PROCESSED
  FAILED
}

enum OutboundMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}
