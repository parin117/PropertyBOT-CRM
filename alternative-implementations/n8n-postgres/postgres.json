        "operation": "executeQuery",
        "query": "INSERT INTO conversation_state (customer_phone, property_type, location, min_price, max_price, last_updated) \nVALUES ($1, $2, $3, $4, $5, CURRENT_TIMESTAMP)\nON CONFLICT (customer_phone) \nDO UPDATE SET \n    property_type = COALESCE(EXCLUDED.property_type, conversation_state.property_type),\n    location = COALESCE(EXCLUDED.location, conversation_state.location),\n    min_price = COALESCE(EXCLUDED.min_price, conversation_state.min_price),\n    max_price = COALESCE(EXCLUDED.max_price, conversation_state.max_price),\n    last_updated = CURRENT_TIMESTAMP\nRETURNING *;",
        "options": {
          "queryReplacement": "=[   \"{{ $json.customer_phone }}\",   \"{{ $json.type }}\",   \"{{ $json.location }}\",   \"{{ $json.min_price }}\",   \"{{ $json.max_price }}\" ]"
        }
