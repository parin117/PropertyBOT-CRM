    {
      "parameters": {
        "jsCode": "const incoming = $('Receive WhatsApp Message').item.json;\n\n// 1. Drop the event immediately if it's NOT a standard user text message\nif (!incoming.messages || !incoming.messages[0] || incoming.messages[0].type !== 'text') {\n    return []; // Empty array stops the workflow silently\n}\n\nconst msgId = incoming.messages[0].id;\nconst userPhone = incoming.contacts[0].wa_id;\n\n// $getWorkflowStaticData only works when the workflow is ACTIVE (Published).\n// It saves data across executions.\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.processedIds) staticData.processedIds = {};\n\n// 2. Check if already processed (Meta Retry Prevention)\nconst key = `${userPhone}:${msgId}`;\nif (staticData.processedIds[key]) {\n  // Duplicate detected — stop execution silently to break the loop\n  return []; \n}\n\n// 3. Mark as processed\nstaticData.processedIds[key] = Date.now();\n\n// 4. Memory management (keep last 200 IDs to avoid unbounded growth)\nconst keys = Object.keys(staticData.processedIds);\nif (keys.length > 200) {\n  keys.sort((a, b) => staticData.processedIds[a] - staticData.processedIds[b]);\n  delete staticData.processedIds[keys[0]];\n}\n\nreturn $input.all();"
      },
