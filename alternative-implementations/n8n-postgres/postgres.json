        "operation": "executeQuery",
        "query": "SELECT \n    p.property_id, \n    p.property_type, \n    p.price, \n    p.address, \n    l.location_name\nFROM properties p\nJOIN locations l ON p.location_id = l.location_id\nWHERE p.available = TRUE\n  AND p.property_type = $1\n  AND l.location_name ILIKE '%' || $2 || '%'\n  AND ($3::numeric IS NULL OR p.price >= $3)\n  AND ($4::numeric IS NULL OR p.price <= $4)\nLIMIT 10;",
        "options": {
          "queryReplacement": "=[   \"{{ $json.property_type }}\",   \"{{ $json.location }}\",   \"{{ $json.min_price }}\",   \"{{ $json.max_price }}\" ]"
        }
