      "parameters": {
        "jsCode": "// The Postgres node outputs rows directly as n8n items\nconst rows = $input.all().map(item => item.json);\n\n// Build the WhatsApp message\nlet reply = `🏡 Here are some matching properties:\\n\\n`;\n\nfor (const row of rows) {\n  reply += `• ID: ${row.property_id || 'N/A'}\\n`;\n  \n  // Notice we use the exact column names returned by your SQL JOIN query\n  reply += `📍 ${row.location_name || ''}\\n`;\n  reply += `🏠 ${row.property_type || ''}\\n`;\n  reply += `💰 ${row.price || ''} Lakh\\n\\n`;\n}\n\nreply += `👨‍💼 Interested in any property?\\n\\nType: Agent\\n\\nOr contact:\\n📞 123456789`;\n\nreturn [{\n  json: {\n    reply: reply\n  }\n}];"
      },
