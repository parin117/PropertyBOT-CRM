    {
      "parameters": {
        "jsCode": "const message = $('Extract Message Text').item.json.messages[0].text.body.toLowerCase();\n\n// 1. Extract Type (Strictly matches your DB CHECK constraint)\nconst typeMatch = message.match(/(flat|bungalow|villa)/);\nlet type = typeMatch ? typeMatch[1] : null;\nif (type) {\n  // Capitalize first letter to match DB exactly ('Flat', 'Bungalow', 'Villa')\n  type = type.charAt(0).toUpperCase() + type.slice(1); \n}\n\n// 2. Extract Location (Add your specific Ahmedabad locations here)\nconst locations = ['gota', 'bopal', 'satellite', 'sg highway', 'thaltej', 'bodakdev', 'science city'];\nconst locMatch = locations.find(loc => message.includes(loc));\nconst location = locMatch || null;\n\n// 3. Extract Max Price (\"under 50\", \"below 60\", \"max 70\", \"less than 80\")\nconst maxMatch = message.match(/(?:under|below|max|less than)\\s*(\\d+)/);\nconst max_price = maxMatch ? Number(maxMatch[1]) : null;\n\n// 4. Extract Min Price (\"above 50\", \"over 60\", \"min 70\", \"50+\")\nconst minMatch = message.match(/(?:above|over|min|more than)\\s*(\\d+)|(\\d+)\\s*\\+/);\nconst min_price = minMatch ? Number(minMatch[1] || minMatch[2]) : null;\n\nreturn [{\n  json: {\n    customer_phone: $('Receive WhatsApp Message').item.json.contacts[0].wa_id,\n    type: type,\n    location: location,\n    max_price: max_price,\n    min_price: min_price\n  }\n}];"
      },
